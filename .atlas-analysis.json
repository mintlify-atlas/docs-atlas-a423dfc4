    "POST /venta_de_bebidas/edit - Editar permiso de bebidas",
    "POST /venta_de_bebidas/aprobate - Aprobar permiso de bebidas",
    "GET /publicidad_y_propaganda - Listar permisos de publicidad",
    "POST /publicidad_y_propaganda/add - Crear permiso de publicidad",
    "POST /publicidad_y_propaganda/edit - Editar permiso de publicidad",
    "GET /eventos_especiales - Listar permisos de eventos",
    "POST /eventos_especiales/add - Crear permiso de eventos",
    "GET /usuarios - Gestión de usuarios del sistema",
    "POST /usuarios/add - Crear nuevo usuario",
